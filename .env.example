# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dental:dental@localhost:5432/dental

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AWS / LocalStack ───────────────────────────────────────────────────────────
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# S3 Buckets (created by localstack init script)
S3_BUCKET_PHI_DOCUMENTS=dental-phi-documents-local
S3_BUCKET_ERA_FILES=dental-era-files-local
S3_BUCKET_EXPORTS=dental-exports-local

# SQS Queues (created by localstack init script)
SQS_QUEUE_REMINDERS=dental-reminders-queue
SQS_QUEUE_ELIGIBILITY=dental-eligibility-queue
SQS_QUEUE_ERA=dental-era-queue
SQS_QUEUE_AUDIT_LOGS=dental-audit-logs-queue

# ─── Cognito ─────────────────────────────────────────────────────────────────────
# Populate after creating Cognito user pool (1.2)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# ─── API ─────────────────────────────────────────────────────────────────────────
API_ENV=development
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# ─── Encryption ──────────────────────────────────────────────────────────────────
# 32-byte base64-encoded key for AES-256 application-layer encryption (PHI fields)
# Generate: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
APP_ENCRYPTION_KEY=

# ─── Secrets (SSM paths in prod, direct values in local dev only) ─────────────────
# Never commit real values for these
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
